# AI Document Pre-Screening (Issue #46)
# Uses Ollama (local) by default. Set ANTHROPIC_API_KEY for Claude API fallback.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llava
ANTHROPIC_API_KEY=
AI_SCREENING_ENABLED=true
AI_SCREENING_TIMEOUT_MS=30000
AI_CONFIDENCE_PASS_THRESHOLD=0.75
AI_CONFIDENCE_FLAG_THRESHOLD=0.40
