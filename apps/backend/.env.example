DATABASE_URL="postgresql://doer:doer_password@localhost:5432/doer_db"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="change_me"
JWT_EXPIRES_IN="7d"
PORT=3000

FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

CLOUDINARY_CLOUD_NAME=
