generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  WORKER
  ADMIN
}

enum JobStatus {
  OPEN
  APPLICATIONS_RECEIVED
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  REVIEWING
  CLOSED
  CANCELLED
}

enum Urgency {
  LOW
  NORMAL
  URGENT
  EMERGENCY
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum VerificationStatus {
  NOT_SUBMITTED
  PENDING
  VERIFIED
  REJECTED
}

enum BadgeLevel {
  TRAINEE
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum PaymentStatus {
  PENDING
  HELD
  RELEASED
  DISPUTED
  REFUNDED
  COMPLETED
}

model User {
  id                 String             @id @default(cuid())
  firebaseUid        String             @unique
  email              String             @unique
  passwordHash       String?
  name               String
  phone              String?
  avatarUrl          String?
  role               Role
  isActive           Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  customerProfile    CustomerProfile?
  workerProfile      WorkerProfile?

  sentMessages       Message[]          @relation("SentMessages")
  notifications      Notification[]
}

model CustomerProfile {
  id        String  @id @default(cuid())
  userId    String  @unique
  address   String?
  latitude  Float?
  longitude Float?

  user      User    @relation(fields: [userId], references: [id])
  jobs      Job[]
  reviews   Review[]
}

model WorkerProfile {
  id                 String             @id @default(cuid())
  userId             String             @unique
  bio                String?
  latitude           Float?
  longitude          Float?
  nicNumber          String?
  nicFrontUrl            String?
  nicBackUrl             String?
  nicVerified            Boolean            @default(false)
  qualificationsVerified Boolean            @default(false)
  backgroundCheckUrl     String?
  backgroundCheckVerified Boolean           @default(false)
  badgeLevel             BadgeLevel         @default(TRAINEE)
  rejectionReason        String?
  verificationStatus     VerificationStatus @default(NOT_SUBMITTED)
  isAvailable        Boolean            @default(true)
  rating             Float              @default(0)
  totalJobs          Int                @default(0)

  user               User               @relation(fields: [userId], references: [id])
  categories         WorkerCategory[]
  jobs               Job[]
  reviews            Review[]
  applications       JobApplication[]
  qualificationDocs  QualificationDoc[]
  portfolio          PortfolioItem[]
}

model QualificationDoc {
  id       String        @id @default(cuid())
  title    String
  url      String
  workerId String

  worker   WorkerProfile @relation(fields: [workerId], references: [id])
}

model ServiceCategory {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  iconUrl     String?

  workers     WorkerCategory[]
  portfolioItems PortfolioItem[]
  jobs        Job[]
}

model WorkerCategory {
  workerId   String
  categoryId String

  worker     WorkerProfile   @relation(fields: [workerId], references: [id])
  category   ServiceCategory @relation(fields: [categoryId], references: [id])

  @@id([workerId, categoryId])
}

model Job {
  id           String          @id @default(cuid())
  title        String
  description  String
  status       JobStatus       @default(OPEN)
  price        Float?
  budgetMin    Float?
  budgetMax    Float?
  urgency      Urgency         @default(NORMAL)
  latitude     Float?
  longitude    Float?
  address      String?
  scheduledAt  DateTime?
  scheduledEnd DateTime?
  imageUrls    String[]
  completedAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  customerId  String
  workerId    String?
  categoryId  String

  customer    CustomerProfile @relation(fields: [customerId], references: [id])
  worker      WorkerProfile?  @relation(fields: [workerId], references: [id])
  category    ServiceCategory @relation(fields: [categoryId], references: [id])

  messages      Message[]
  review        Review?
  payment       Payment?
  applications  JobApplication[]
}

model JobApplication {
  id        String            @id @default(cuid())
  status    ApplicationStatus @default(PENDING)
  message   String?
  price     Float?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  jobId     String
  workerId  String

  job       Job           @relation(fields: [jobId], references: [id])
  worker    WorkerProfile @relation(fields: [workerId], references: [id])

  @@unique([jobId, workerId])
}

model Review {
  id         String          @id @default(cuid())
  rating     Int
  comment    String?
  photoUrls  String[]
  createdAt  DateTime        @default(now())

  jobId      String          @unique
  customerId String
  workerId   String

  job        Job             @relation(fields: [jobId], references: [id])
  customer   CustomerProfile @relation(fields: [customerId], references: [id])
  worker     WorkerProfile   @relation(fields: [workerId], references: [id])
}

model PortfolioItem {
  id          String           @id @default(cuid())
  imageUrl    String
  caption     String?
  createdAt   DateTime         @default(now())

  workerId    String
  categoryId  String?

  worker      WorkerProfile    @relation(fields: [workerId], references: [id])
  category    ServiceCategory? @relation(fields: [categoryId], references: [id])
}

model Message {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  jobId     String
  senderId  String

  job       Job      @relation(fields: [jobId], references: [id])
  sender    User     @relation("SentMessages", fields: [senderId], references: [id])
}

model Payment {
  id            String        @id @default(cuid())
  amount        Float
  status        PaymentStatus @default(PENDING)
  payhereRef    String?
  heldAt        DateTime?
  releasedAt    DateTime?
  disputedAt    DateTime?
  refundedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt @default(now())

  jobId         String        @unique
  job           Job           @relation(fields: [jobId], references: [id])
  dispute       Dispute?
}

model Dispute {
  id               String   @id @default(cuid())
  reason           String
  description      String
  customerEvidence String[]
  workerResponse   String?
  workerEvidence   String[]
  resolution       String?
  resolvedBy       String?
  resolvedAt       DateTime?
  createdAt        DateTime @default(now())

  paymentId        String   @unique
  payment          Payment  @relation(fields: [paymentId], references: [id])
  raisedBy         String
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  body      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id])
}
